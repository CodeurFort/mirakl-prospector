# Supabase (service role key — never expose client-side)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=sb_secret_YOUR_SERVICE_ROLE_KEY

# Apify — used by find_contacts.py (Google Search scraper)
APIFY_TOKEN=apify_api_YOUR_TOKEN

# Apollo — optional, used by enrich_one.py for company size fallback
APOLLO_API_KEY=

# Better Contact — primary + optional fallback (auto-switch on credits/auth errors)
BETTERCONTACT_API_KEY=YOUR_PRIMARY_KEY
BETTERCONTACT_API_KEY_FALLBACK=YOUR_FALLBACK_KEY
