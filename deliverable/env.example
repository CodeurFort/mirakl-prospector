# ═════════════════════════════════════════════════════════════════════════
# Next.js app (.env.local + Vercel production)
# ═════════════════════════════════════════════════════════════════════════

# Supabase — public URL + service role key (serverless-only)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_YOUR_SERVICE_ROLE_KEY

# OpenAI — classification + email generation + competitor analysis
OPENAI_API_KEY=sk-proj-YOUR_KEY

# Better Contact — primary + optional fallback (auto-switch on credits/auth errors or on-hold responses)
BETTERCONTACT_API_KEY=YOUR_PRIMARY_KEY
BETTERCONTACT_API_KEY_FALLBACK=YOUR_FALLBACK_KEY

# SMTP — Google Workspace (app password, 16 chars)
# Generate from https://myaccount.google.com/apppasswords (2FA required on the account)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.sender@yourdomain.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=your.sender@yourdomain.com

# Dev only — ignored on Vercel (no Python runtime in prod)
PYTHON_PATH=/usr/bin/python3


# ═════════════════════════════════════════════════════════════════════════
# Python scraper (scraper/.env)
# ═════════════════════════════════════════════════════════════════════════

# Supabase (same project — service role key, not anon)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=sb_secret_YOUR_SERVICE_ROLE_KEY

# Apify — used by find_contacts.py (Google Search scraper)
APIFY_TOKEN=apify_api_YOUR_TOKEN

# Apollo — optional, used by the legacy enrich_one.py for company size fallback
APOLLO_API_KEY=

# Better Contact — same keys as the Next.js app
BETTERCONTACT_API_KEY=YOUR_PRIMARY_KEY
BETTERCONTACT_API_KEY_FALLBACK=YOUR_FALLBACK_KEY
